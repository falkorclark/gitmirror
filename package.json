{
  "name": "@neverending/gitmirror",
  "version": "1.0.1",
  "description": "Command line tool for mirroring one or more git repositories",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/falkorclark/gitmirror.git"
  },
  "bin": {
    "gitmirror": "lib/bin/cli.js"
  },
  "module": "./lib/gitmirror.js",
  "main": "./lib/gitmirror.js",
  "types": "./lib/gitmirror.d.ts",
  "exports": {
    ".": "./lib/gitmirror.js",
    "./lib/*.js": "./lib/*.js",
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "tests"
  ],
  "scripts": {
    "start": "node --import tsx src/bin/cli.ts",
    "build": "node --import tsx src/bin/build.ts",
    "test": "npx eslint src --quiet && node --import tsx src/bin/test.ts"
  },
  "author": "Falkor Clark <falkorclark@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "git",
    "mirrors",
    "mirror",
    "gitmirror",
    "gitmirrors"
  ],
  "dependencies": {
    "colors": "^1.4.0",
    "fs-extra": "^11.3.4",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
